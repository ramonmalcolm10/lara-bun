{
    "name": "larabun/lara-bun",
    "description": "A Laravel-to-Bun bridge via Unix sockets",
    "type": "library",
    "keywords": [
        "laravel",
        "bun",
        "javascript",
        "typescript",
        "unix-socket",
        "ssr",
        "inertia"
    ],
    "homepage": "https://github.com/larabun/lara-bun",
    "authors": [
        {
            "name": "Ramon Malcolm",
            "homepage": "https://github.com/ramonmalcolm10"
        }
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/console": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "mockery/mockery": "^1.6",
        "inertiajs/inertia-laravel": "^2.0"
    },
    "suggest": {
        "inertiajs/inertia-laravel": "Required for Bun SSR gateway"
    },
    "autoload": {
        "psr-4": {
            "LaraBun\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest"
    },
    "extra": {
        "laravel": {
            "providers": [
                "LaraBun\\BunServiceProvider"
            ],
            "aliases": {
                "Bun": "LaraBun\\Facades\\Bun"
            }
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
